# Главная страница - не кешировать
/
  Cache-Control: no-cache, must-revalidate, max-age=0

# Все HTML - не кешировать  
/*.html
  Cache-Control: no-cache, must-revalidate, max-age=0

# JS/CSS статика - не кешировать (пока хеши нестабильны)
/_next/static/chunks/*
  Cache-Control: no-cache, must-revalidate, max-age=0
